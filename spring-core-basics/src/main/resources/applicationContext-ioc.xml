<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

  <bean id="bean1" class="cn.jackiegu.spring.core.basics.xml.ioc.SpringXmlIocBean"/>

  <bean id="bean2" class="cn.jackiegu.spring.core.basics.xml.ioc.SpringXmlIocBean" factory-method="instance"/>

  <bean id="beanFactory" class="cn.jackiegu.spring.core.basics.xml.ioc.SpringXmlIocBeanFactory"/>
  <bean id="bean3" factory-bean="beanFactory" factory-method="generate"/>

</beans>